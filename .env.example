# Stellar
STELLAR_SECRET_KEY=your_stellar_secret_key_here
STELLAR_NETWORK=testnet
STELLAR_HORIZON_URL=https://horizon-testnet.stellar.org

# Contract Addresses (fill after deployment)
VERIFIER_CONTRACT_ID=
PAYMENT_CONTRACT_ID=
REPUTATION_CONTRACT_ID=
INSURANCE_CONTRACT_ID=

# RISC Zero
BONSAI_API_KEY=your_bonsai_api_key_here
BONSAI_API_URL=https://api.bonsai.xyz

# Guardian Agent
GUARDIAN_POLL_INTERVAL=5
PAYMENT_CONFIDENCE_THRESHOLD=0.95
ANOMALY_THRESHOLD=3

# LLM (optional - for AssistantAgent)
OLLAMA_URL=http://localhost:11434
OLLAMA_MODEL=mistral

# API security
# Comma-separated list of allowed CORS origins. Use "*" to open to all (NOT recommended).
ALLOWED_ORIGINS=http://localhost:8000,http://localhost:3000
# When set, all money-moving / state-changing endpoints require this value in the X-API-Key header.
# Leave empty ONLY for local dev. Always set a strong random value in any real deployment.
ZEROSENSE_API_KEY=
